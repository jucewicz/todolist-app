# Banco de dados (não alterar para uso local com Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/todolist

# Segurança — troque por uma string aleatória longa
SECRET_KEY=troque-por-uma-chave-secreta-longa

# Obrigatório — crie sua chave em https://aistudio.google.com/
GEMINI_API_KEY=

# Tokens (valores padrão recomendados)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
